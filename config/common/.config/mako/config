# Mako notification config — Catppuccin Mocha

# Posizione e dimensioni
anchor=top-right
margin=12
padding=12,16
width=360
height=150
border-size=2
border-radius=8

# Colori base (Catppuccin Mocha)
background-color=#1e1e2eee
text-color=#cdd6f4
border-color=#89b4facc

# Tipografia
font=JetBrains Mono 11

# Comportamento
default-timeout=5000
ignore-timeout=0
max-visible=5
sort=-time

# Icone
icons=1
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=64

# Formato
format=<b>%s</b>\n%b
markup=1

[urgency=low]
border-color=#45475acc
default-timeout=3000

[urgency=normal]
border-color=#89b4facc
default-timeout=5000

[urgency=critical]
border-color=#f38ba8ff
background-color=#2a1a1eee
text-color=#ffffff
default-timeout=0
